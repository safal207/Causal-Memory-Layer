# Copy this file to a private shell profile or export the values manually.
# Never commit real credentials or connection strings.

# CockroachDB Cloud
COCKROACH_CLUSTER=liminal-recall
DATABASE_URL=postgresql://<user>:<password>@<host>:26257/defaultdb?sslmode=verify-full

# AWS
AWS_REGION=us-east-1
STACK_NAME=liminal-recall

# Optional public-demo protection. Use a long random value and share it only
# through the private Devpost testing-instructions field.
DEMO_API_KEY=<generate-a-long-random-value>

# Runtime tuning
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSIONS=256
SIMILARITY_THRESHOLD=0.35
